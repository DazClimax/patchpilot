[Unit]
Description=PatchPilot Server
After=network.target

[Service]
Type=simple
User=patchpilot
Group=patchpilot
WorkingDirectory=/opt/patchpilot/server
EnvironmentFile=/opt/patchpilot/.env
ExecStart=/opt/patchpilot-venv/bin/uvicorn app:app --host 0.0.0.0 --port ${PORT}
Restart=always
RestartSec=5
# Hardening
NoNewPrivileges=yes
PrivateTmp=yes

[Install]
WantedBy=multi-user.target
